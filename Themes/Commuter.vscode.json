{
	"name": "Commuter",
	"author": "Ted Broberg",
	"type": "dark",
	"semanticHighlighting": true,
	"tokenColors": [
		{
			"name": "Comment",
			"scope": "comment",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#CCCC99"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword",
				"storage.type.primitive"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Namespace",
			"scope": [
				"keyword",
				"storage.type.namespace"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Storage Modifier",
			"scope": [
				"keyword",
				"storage.modifier"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Number",
			"scope": "constant.numeric",
			"settings": {
				"fontStyle": "",
				"foreground": "#FF9933"
			}
		},
		{
			"name": "User-defined constant",
			"scope": "constant",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Built-in constant",
			"scope": "constant.language",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Variable",
			"scope": [
				"variable.language",
				"variable.other"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "String",
			"scope": "string",
			"settings": {
				"fontStyle": "",
				"foreground": "#FF8686"
			}
		},
		{
			"name": "String interpolation",
			"scope": [
				"constant.character.escape",
				"string source"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#FF0099"
			}
		},
		{
			"name": "Preprocessor line",
			"scope": "meta.preprocessor",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Preprocessor directive",
			"scope": "keyword.control.import",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Function name",
			"scope": [
				"entity.name.function",
				"support.function.any-method"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Type name",
			"scope": "entity.name.type",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CC66"
			}
		},
		{
			"name": "Inherited class name",
			"scope": "entity.other.inherited-class",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#99CC66"
			}
		},
		{
			"name": "Function parameter",
			"scope": "variable.parameter",
			"settings": {
				"fontStyle": "",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Function argument and result types",
			"scope": "storage.type.method",
			"settings": {
				"fontStyle": "",
				"foreground": "#70727E"
			}
		},
		{
			"name": "Custom Class",
			"scope": "storage.type",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CC66"
			}
		},
		{
			"name": "Imports",
			"scope": "storage.type.import",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Punctuation Terminator",
			"scope": "punctuation.terminator",
			"settings": {
				"fontStyle": "",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Section",
			"scope": [
				"meta.section entity.name.section",
				"declaration.section entity.name.section"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Library function",
			"scope": "support.function",
			"settings": {
				"fontStyle": "",
				"foreground": "#66CCCC"
			}
		},
		{
			"name": "Library object",
			"scope": [
				"support.class",
				"support.type"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#99CC66"
			}
		},
		{
			"name": "Library constant",
			"scope": "support.constant",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Library variable",
			"scope": "support.variable",
			"settings": {
				"fontStyle": "",
				"foreground": "#88BFFE"
			}
		},
		{
			"name": "JS: Operator",
			"scope": "keyword.operator.js",
			"settings": {
				"fontStyle": "",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Invalid",
			"scope": "invalid",
			"settings": {
				"background": "#990000",
				"foreground": "#FFFFFF"
			}
		},
		{
			"name": "Invalid trailing whitespace",
			"scope": "invalid.deprecated.trailing-whitespace",
			"settings": {
				"background": "#77CC88",
				"fontStyle": "",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Embedded source",
			"scope": [
				"text source",
				"string.unquoted"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Embedded embedded source",
			"scope": [
				"text source string.unquoted",
				"text source text source"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Markup XML declaration",
			"scope": "meta.tag.preprocessor.xml",
			"settings": {
				"fontStyle": "",
				"foreground": "#68685B"
			}
		},
		{
			"name": "Markup DOCTYPE",
			"scope": [
				"meta.tag.sgml.doctype",
				"meta.tag.sgml.doctype entity",
				"meta.tag.sgml.doctype string",
				"meta.tag.preprocessor.xml",
				"meta.tag.preprocessor.xml entity",
				"meta.tag.preprocessor.xml string"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Markup DTD",
			"scope": "string.quoted.docinfo.doctype.DTD",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Markup tag",
			"scope": [
				"meta.tag",
				"declaration.tag"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Markup name of tag",
			"scope": "entity.name.tag",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Markup tag attribute",
			"scope": "entity.other.attribute-name",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CC66"
			}
		},
		{
			"name": "Markup: Heading",
			"scope": "markup.heading",
			"settings": {
				"fontStyle": "",
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Markup: Quote",
			"scope": "markup.quote",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#CCCC99"
			}
		},
		{
			"name": "Markup: List",
			"scope": "markup.list",
			"settings": {
				"foreground": "#99CCFF"
			}
		},
		{
			"name": "Markup: Link",
			"scope": [
				"markup.underline.link",
				"string.other.link"
			],
			"settings": {
				"fontStyle": "underline",
				"foreground": "#66CCCC"
			}
		},
		{
			"name": "Markup: Bold",
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Markup: Italic",
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#DADADA"
			}
		},
		{
			"name": "Markup: Inserted",
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#79B24F"
			}
		},
		{
			"name": "Markup: Deleted",
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#FF5252"
			}
		},
		{
			"name": "Markup: Changed",
			"scope": "markup.changed",
			"settings": {
				"foreground": "#FF9933"
			}
		}
	],
